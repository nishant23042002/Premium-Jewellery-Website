# --- App ---
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Shree Ambika Jewellers"

# --- Database (MongoDB Atlas or self-hosted) ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ambika-jewellers

# --- Auth (JWT) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Configure a webhook in the Razorpay dashboard (Settings > Webhooks) pointed
# at <site>/api/razorpay/webhook, subscribed to payment.captured and
# payment.failed, and paste the secret it gives you here. Leave blank to keep
# the webhook route disabled (payments still work via the client-side verify
# callback alone; the webhook is a fallback for when that callback never
# fires — see app/api/razorpay/webhook/route.ts).
RAZORPAY_WEBHOOK_SECRET=

# --- Metals.Dev (optional — live gold/silver/platinum rates) ---
# Sign up at https://metals.dev/dashboard. Leave blank to keep the Pricing
# Dashboard in manual-entry-only mode.
METALS_DEV_API_KEY=
# Authenticates the scheduled fetch route (app/api/cron/refresh-metal-rates).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# --- Resend (optional — transactional email) ---
# Sign up at https://resend.com/api-keys. Leave blank to keep sendEmail() as
# a logged no-op. Until a sending domain is verified at resend.com/domains,
# sends are sandboxed to the account owner's own inbox.
RESEND_API_KEY=

# --- Google OAuth (optional — "Continue with Google" customer sign-in) ---
# Create an OAuth client at https://console.cloud.google.com (APIs & Services
# > Credentials > Create Credentials > OAuth client ID > Web application).
# Add "<site>/api/auth/google/callback" as an authorized redirect URI. Leave
# both blank to keep the Google sign-in button hidden.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Same value as GOOGLE_CLIENT_ID above — the client ID isn't a secret, this
# copy just lets the browser know whether to show the button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Admin panel gate (optional — hides /admin from automated scanners) ---
# When set, /admin/* (including /admin/login) 404s for anyone who hasn't
# first visited /api/admin-gate?key=<this value>, which sets a long-lived
# cookie unlocking it. Leave blank to keep /admin reachable directly at its
# normal path (today's behavior). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Treat the resulting unlock URL like a password — share it only out of
# band (not email/chat you wouldn't trust with a password), and only with
# people who need admin access.
ADMIN_GATE_SECRET=

# --- Google Places (optional — real Google Reviews on the Testimonials page) ---
# Create/reuse an API key at https://console.cloud.google.com (APIs & Services
# > Credentials), with the "Places API" enabled. Find GOOGLE_PLACE_ID for the
# business listing at https://developers.google.com/maps/documentation/places/web-service/place-id
# (search for the business by name/address). Leave either blank to keep the
# Testimonials page showing only the manually-curated Testimonial records —
# reviews are fetched server-side and cached in MongoDB, so if the Places API
# ever fails or the key is revoked later, the page keeps showing the last 4
# successfully-fetched reviews instead of breaking or erroring.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
